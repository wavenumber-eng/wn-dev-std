{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wavenumber-eng/wn-dev-std/docs/contracts/command_manifest.a0.schema.json",
  "title": "CLI command manifest a0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "commands"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "wn_dev_std.command_manifest.a0"
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/command" }
    }
  },
  "$defs": {
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "design_doc"],
      "allOf": [
        {
          "anyOf": [
            { "required": ["path"] },
            { "required": ["name"] }
          ]
        },
        {
          "anyOf": [
            { "required": ["summary"] },
            { "required": ["description"] }
          ]
        }
      ],
      "properties": {
        "path": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "name": {
          "minLength": 1,
          "type": "string",
          "description": "Human-readable full command name. When present, it should match the joined path."
        },
        "status": {
          "type": "string",
          "enum": ["public", "experimental", "deprecated", "hidden", "deferred"]
        },
        "summary": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "design_doc": { "type": "string", "minLength": 1 },
        "data_command": {
          "type": "string",
          "minLength": 1,
          "description": "Design-doc command marker when it differs from the joined path."
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "requires_extras": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "surface_ref": { "type": "string" },
        "issue_refs": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "exception_refs": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "implementation_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/typedRef" }
        },
        "verification_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/typedRef" }
        },
        "config_contracts": {
          "type": "array",
          "items": { "$ref": "#/$defs/contractRef" }
        },
        "output_contracts": {
          "type": "array",
          "items": { "$ref": "#/$defs/contractRef" }
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "typedRef": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "target", "coverage_mode", "rationale"],
      "properties": {
        "kind": { "type": "string" },
        "target": { "type": "string" },
        "repo": { "type": "string" },
        "coverage_mode": { "type": "string" },
        "rationale": { "type": "string" }
      }
    },
    "contractRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "mode"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 }
      }
    }
  }
}
