{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wavenumber-eng/wn-dev-std/docs/contracts/wn_dev_std_config.schema.v0.json",
  "title": "wn-dev-std pyproject configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "profile": {
      "type": "string",
      "enum": ["python-package", "python-native-wasm", "cpp-library"],
      "description": "Primary project profile such as python-package, python-native-wasm, or cpp-library."
    },
    "distribution": {
      "type": "string",
      "enum": ["pypi", "internal", "none"],
      "description": "Distribution target for release workflows."
    },
    "languages": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Languages used by the project."
    },
    "strict": {
      "type": "boolean",
      "description": "Whether strict new-project rules apply."
    },
    "artifact_policy": {
      "type": "string",
      "enum": ["transient-dist", "committed-grouped-dist"],
      "description": "Whether dist/ is transient packaging output or committed grouped runtime artifacts."
    }
  }
}
